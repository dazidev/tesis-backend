generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  admin
  lawyer
  client
}

enum UserStatus {
  active
  inactive
  suspended
}

model User {
  id             String      @default(uuid()) @id
  name           String
  lastname       String
  email          String      @unique
  password       String
  invitationCode String?
  roles          UserRole[]
  status         UserStatus  @default(active)
  lawyerId       String?

  createdAt      DateTime    @default(now()) @db.Timestamptz()
  updatedAt      DateTime    @updatedAt @db.Timestamptz()

  @@index([email])
  @@index([roles])
  @@map("users")
}
